{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "relay/Dockerfile",
    "watchPatterns": [
      "relay/**",
      "shared/**",
      "package.json",
      "tsconfig.base.json",
      "relay/Dockerfile",
      "railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
